# Free tier: 250 calls/day — enough for dev + homologation tests.
# Starter ~$22/mo — production batch refresh (under $30 budget).
# Register: https://site.financialmodelingprep.com/register
#
# Copy this file to .env and paste your key (never commit .env or share in chat):
#   copy .env.example .env
FMP_API_KEY=your_fmp_key_here

# SEC EDGAR (required for ?source=edgar) — real email, SEC policy
SEC_USER_AGENT=ValueInvestingAnalyzer your.email@example.com
